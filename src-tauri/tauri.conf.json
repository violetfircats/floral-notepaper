{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "花笺",
  "version": "1.0.2",
  "identifier": "com.floral-notepaper.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "花笺",
        "width": 1180,
        "height": 760,
        "minWidth": 900,
        "minHeight": 620,
        "decorations": false,
        "visible": false,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg", "nsis"],
    "publisher": "Floral Notepaper",
    "copyright": "Copyright © 2025 Floral Notepaper",
    "shortDescription": "花笺 - 轻量跨平台桌面便签",
    "longDescription": "花笺是一款轻量级跨平台桌面便签应用，支持 Markdown 编辑、桌面磁贴、系统托盘快捷操作。",
    "macOS": {
      "minimumSystemVersion": "15.0"
    },
    "windows": {
      "nsis": {
        "installMode": "both",
        "languages": ["SimpChinese"],
        "displayLanguageSelector": false,
        "installerHooks": "nsis-hooks.nsh"
      }
    },
    "fileAssociations": [
      {
        "ext": ["md", "markdown"],
        "name": "Markdown Document",
        "description": "Markdown document file",
        "role": "Editor"
      }
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
